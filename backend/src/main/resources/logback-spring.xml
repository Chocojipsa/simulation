<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!--
        Suppress Broken pipe errors from Tomcat's async (SSE) processing.
        These are expected when SSE clients disconnect (browser tab close, navigation, network drop).
        Application-level error handling in SimulationEventHub already handles cleanup properly.
    -->
    <logger name="org.apache.catalina.core.ContainerBase.[Tomcat].[localhost].[/].[dispatcherServlet]"
            level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
